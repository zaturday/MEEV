{
  "name": "meev-server",
  "version": "1.0.0",
  "description": "MEEV News Auto-Fetch Server — ดึงข่าว EV ไทยอัตโนมัติทุกวัน 6:00 AM",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "fetch-now": "node -e \"import('./fetchers/rss-fetcher.js').then(m => m.fetchAllRSS()).then(r => console.log(JSON.stringify(r.slice(0,3), null, 2)))\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
  }
}
